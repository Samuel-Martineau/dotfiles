{
  // #############################################################
  // ########################## General ##########################
  // #############################################################
  // Workbench
  "workbench.iconTheme": "material-icon-theme",
  "workbench.editorAssociations": {
    "*.jpeg": "imagePreview.previewEditor",
    "*.jpg": "imagePreview.previewEditor",
    "*.png": "imagePreview.previewEditor",
    "*.ipynb": "jupyter-notebook"
  },
  "workbench.colorTheme": "Codel",
  // Editor
  "editor.fontFamily": "'JetBrainsMono Nerd Font'",
  "editor.fontSize": 12,
  "editor.fontLigatures": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.inlineSuggest.enabled": true,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": true
  },
  "editor.tabSize": 2,
  // Security
  "security.workspace.trust.untrustedFiles": "prompt",
  // Explorer
  "explorer.compactFolders": false,
  // Terminal
  "terminal.external.osxExec": "iTerm.app",
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font'",
  // Window
  "window.zoomLevel": 0.75,
  // Files
  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true
  },
  // Notebook
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  // #############################################################
  // ######################## Extensions #########################
  // #############################################################
  // Prettier
  "prettier.tabWidth": 2,
  // LiveShare
  "liveshare.presence": true,
  // Redhat
  "redhat.telemetry.enabled": false,
  // Gremlins
  "gremlins.showInProblemPane": true,
  // Copilot
  "github.copilot.enable": {
    "*": false
  },
  // #############################################################
  // ######################### Languages #########################
  // #############################################################
  // Python
  "python.defaultInterpreterPath": "/Users/samuelmartineau/.asdf/shims/python",
  "python.analysis.typeCheckingMode": "basic",
  "python.languageServer": "Pylance",
  "python.formatting.provider": "black",
  "python.terminal.activateEnvironment": true,
  "[python]": {
    "editor.wordBasedSuggestions": false,
    "editor.defaultFormatter": "ms-python.python"
  },
  // NGINX
  "[nginx]": {
    "editor.defaultFormatter": "raynigon.nginx-formatter"
  },
  // Dockerfile
  "[dockerfile]": {
    "editor.quickSuggestions": {
      "strings": true
    },
    "editor.defaultFormatter": "ms-azuretools.vscode-docker"
  },
  // XML
  "[xml]": {
    "editor.autoClosingBrackets": "never",
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": false,
    "editor.defaultFormatter": "redhat.vscode-xml"
  },
  // TypeScript
  "typescript.updateImportsOnFileMove.enabled": "always",
  // JavaScript
  "javascript.updateImportsOnFileMove.enabled": "always",
  // TOML
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  // Markdown
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": false,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // Svelte
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode"
  },
  // Astro
  "[astro]": {
    "editor.defaultFormatter": "astro-build.astro-vscode"
  }
}
