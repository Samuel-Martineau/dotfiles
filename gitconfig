[user]
    name = Samuel Martineau
    email = samumartineau@gmail.com

[credential]
    helper = osxkeychain

[core]
    pager = delta

[delta]
    plus-style = "syntax #012800"
    minus-style = "syntax #340001"
    side-by-side = true
    line-numbers = true
    syntax-theme = Monokai Extended
    navigate = true

[interactive]
    diffFilter = delta --color-only

[include]
    path = ~/.gitconfig_local

[init]
	defaultBranch = main
[pull]
	rebase = false
